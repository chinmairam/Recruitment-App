<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Approval_Status_Change</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
ISCHANGED( Approval_Status__c ),
NOT(ISNEW())
)</errorConditionFormula>
    <errorDisplayField>Approval_Status__c</errorDisplayField>
    <errorMessage>User not allowed to change Approval Status value manually.</errorMessage>
</ValidationRule>
